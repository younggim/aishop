# Auth.js (NextAuth v5) configuration
# Generate with: npx auth secret
AUTH_SECRET=

# Google OAuth credentials
# Create at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Toss Payments — public widget test client key (Toss's published sandbox key, safe to use as-is)
# Get your own merchant keys at https://developers.tosspayments.com/my/api-keys
NEXT_PUBLIC_TOSS_CLIENT_KEY=test_ck_D5GePWvyJnrK0W0k6q8gLzN97Eoq
# Secret key is required to call the server-side confirm API. Without it, test payments
# stay "authorized" but are never confirmed (Toss auto-cancels unconfirmed payments).
TOSS_SECRET_KEY=

# Kakao Pay — get CID and Admin Key from https://business.kakao.com (카카오페이 > 결제 연동)
# TC0ONETIME is Kakao's shared sandbox CID for testing without a real contract.
KAKAO_PAY_CID=TC0ONETIME
KAKAO_PAY_ADMIN_KEY=
